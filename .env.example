# ─── Base de Dados PostgreSQL (OBRIGATÓRIO) ────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Exemplo local:  postgresql://medfreela:senha123@localhost:5432/medfreela
# Exemplo remoto: postgresql://medfreela:senha123@192.168.1.10:5432/medfreela
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/medfreela"

# ─── Segredo de sessão (OBRIGATÓRIO em produção) ───────────────────────────────
# Gerar com: openssl rand -hex 32
AUTH_SECRET="ALTERAR-para-string-aleatoria-segura-32chars+"
