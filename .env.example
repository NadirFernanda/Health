# ─── Base de Dados PostgreSQL (OBRIGATÓRIO) ────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Exemplo local:  postgresql://medfreela:senha123@localhost:5432/medfreela
# Exemplo remoto: postgresql://medfreela:senha123@192.168.1.10:5432/medfreela
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/medfreela"

# ─── Segredo de sessão HMAC-SHA256 (OBRIGATÓRIO) ──────────────────────────────
# Mínimo 32 caracteres. Gerar com: openssl rand -hex 32
# ATENÇÃO: Alterar invalida TODAS as sessões activas dos utilizadores.
# NUNCA use o valor de exemplo em produção.
AUTH_SECRET="GERE_COM_openssl_rand_hex_32_NUNCA_USE_ESTE_VALOR"

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
