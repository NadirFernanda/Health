// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MEDICO
  CLINICA
  PROFISSIONAL
  PROPRIETARIO_SALA
}

enum TipoProfissional {
  MEDICO
  ENFERMEIRO
  TECNICO_SAUDE
  OUTRO
}

enum EstadoPlantao {
  ABERTO
  FECHADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum EstadoCandidatura {
  PENDENTE
  ACEITE
  RECUSADO
  CANCELADA
}

enum EstadoDocumento {
  NAO_ENVIADO
  PENDENTE
  APROVADO
  REJEITADO
}

enum TipoTransacao {
  CREDITO
  DEBITO
}

enum EstadoTransacao {
  PENDENTE
  PROCESSANDO
  CONFIRMADO
  PROCESSADO
  FALHOU
  REEMBOLSADO
}

enum TipoSala {
  CONSULTORIO
  OBSERVACAO
  PROCEDIMENTOS
  SALA_CURATIVO
  OUTRO
}

enum EstadoReserva {
  PENDENTE_PAGAMENTO
  CONFIRMADA
  CANCELADA
  CANCELADA_PROFISSIONAL
  CANCELADA_CLINICA
  CONCLUIDA
}

enum CredencialTipo {
  BI_PASSAPORTE
  CEDULA_OMA
  REGISTO_SINOME
  DIPLOMA_LICENCIATURA
  CERTIFICADO_ESPECIALIZACAO
  OUTRO
}

enum CredencialEstado {
  PENDENTE
  APROVADO
  REJEITADO
  EXPRESS_PENDENTE
}

enum PagamentoTipo {
  TURNO
  SALA
}

enum PagamentoMetodo {
  MULTICAIXA_EXPRESS
  TRANSFERENCIA_BANCARIA
  TPA
}

enum PagamentoEstado {
  PENDENTE
  PROCESSANDO
  CONFIRMADO
  FALHOU
  REEMBOLSADO
}

enum AvaliacaoTipo {
  TURNO
  SALA
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  phone        String?
  passwordHash String
  role         Role
  criadoEm    DateTime      @default(now())
  updatedEm   DateTime      @updatedAt
  isActive    Boolean       @default(true)
  verifiedAt  DateTime?
  lastLoginAt DateTime?

  profissional Profissional?
  clinica      Clinica?
  notificacoes Notificacao[]
  credenciaisVerificadas Credencial[] @relation("CredencialVerificadaPor")
}

model Profissional {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome                String
  tipo                TipoProfissional   @default(MEDICO)
  especialidade       String
  numeroOrdem         String?
  numeroSinome        String?            @unique
  numeroOma           String?
  provincia           String             @default("Luanda")
  cidade              String?
  bairro              String?
  foto                String?
  bio                 String?
  anosExperiencia     Int?
  subEspecialidade    String?
  rating              Float              @default(0)
  totalAvaliacoes     Int                @default(0)
  totalPlantoes       Int                @default(0)
  verified            Boolean            @default(false)
  verificadoEm        DateTime?
  saldoCarteira       Int                @default(0)
  saldoCarteiraCentavos BigInt           @default(0)
  disponivelAgora     Boolean            @default(false)

  candidaturas        Candidatura[]
  documentos          Documento[]
  credenciais         Credencial[]
  avaliacoesFeitas    Avaliacao[]        @relation("AutorAvaliacao")
  avaliacoesRecebidas Avaliacao[]        @relation("AlvoMedicoAvaliacao")
  reservas            ReservaSala[]
  transacoes          TransacaoCarteira[]

  @@index([tipo])
  @@index([especialidade])
  @@index([verified])
  @@index([disponivelAgora])
}

model Clinica {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome            String
  alvara          String?
  morada          String?
  bairro          String?
  zonaLuanda      String?
  latitude        Decimal?   @db.Decimal(10, 7)
  longitude       Decimal?   @db.Decimal(10, 7)
  contacto        String?
  website         String?
  cidade          String?
  provincia       String    @default("Luanda")
  logo            String?
  descricao       String?
  rating          Float     @default(0)
  totalAvaliacoes Int       @default(0)
  verified        Boolean   @default(false)
  criadoEm        DateTime  @default(now())
  updatedEm       DateTime  @updatedAt

  plantoes            Plantao[]
  salas               Sala[]
  avaliacoesRecebidas Avaliacao[] @relation("AlvoClinicaAvaliacao")

  @@index([zonaLuanda])
  @@index([verified])
}

model Plantao {
  id               String           @id @default(cuid())
  clinicaId        String
  clinica          Clinica          @relation(fields: [clinicaId], references: [id])
  salaId           String?
  sala             Sala?            @relation(fields: [salaId], references: [id])
  tipoProfissional TipoProfissional @default(MEDICO)
  especialidade    String
  dataInicio       DateTime
  dataFim          DateTime
  valorKwanzas     Int
  valorCentavos    BigInt?
  vagas            Int
  vagasPreenchidas Int              @default(0)
  estado           EstadoPlantao   @default(ABERTO)
  descricao        String?

  // Equipamentos
  maca             Boolean @default(false)
  estetoscopio     Boolean @default(false)
  tensiometro      Boolean @default(false)
  termometro       Boolean @default(false)
  computador       Boolean @default(false)
  materiaisBasicos Boolean @default(true)
  nebulizador      Boolean @default(false)
  oximetro         Boolean @default(false)
  glucometro       Boolean @default(false)
  desfibrilador    Boolean @default(false)

  candidaturas Candidatura[]
  pagamentos  Pagamento[]
  avaliacoes   Avaliacao[]
  criadoEm    DateTime      @default(now())
  atualizadoEm DateTime     @updatedAt

  @@index([clinicaId])
  @@index([especialidade])
  @@index([tipoProfissional])
  @@index([dataInicio])
  @@index([estado])
}

model Candidatura {
  id             String            @id @default(cuid())
  plantaoId      String
  plantao        Plantao           @relation(fields: [plantaoId], references: [id])
  profissionalId String
  profissional   Profissional      @relation(fields: [profissionalId], references: [id])
  estado         EstadoCandidatura @default(PENDENTE)
  mensagem       String?
  criadoEm      DateTime          @default(now())
  respondidoEm  DateTime?
  pagamentos    Pagamento[]

  @@unique([plantaoId, profissionalId])
  @@index([plantaoId])
  @@index([profissionalId])
  @@index([estado])
}

model Sala {
  id               String    @id @default(cuid())
  clinicaId        String
  clinica          Clinica   @relation(fields: [clinicaId], references: [id])
  nome             String
  numero           String?
  tipo             TipoSala
  precoPorHora     Int
  precoPorHoraCentavos BigInt?
  zona             String
  descricao        String?
  fotos            String[]  @default([])
  politicaCancel   String?
  ativo            Boolean   @default(true)
  disponivel       Boolean   @default(true)
  avaliacaoMedia   Float     @default(0)
  totalAvaliacoes  Int       @default(0)

  // Equipamentos
  maca             Boolean @default(false)
  estetoscopio     Boolean @default(false)
  tensiometro      Boolean @default(false)
  termometro       Boolean @default(false)
  computador       Boolean @default(false)
  materiaisBasicos Boolean @default(true)
  nebulizador      Boolean @default(false)
  oximetro         Boolean @default(false)
  glucometro       Boolean @default(false)
  desfibrilador    Boolean @default(false)

  reservas         ReservaSala[]
  disponibilidades DisponibilidadeSala[]
  avaliacoes       Avaliacao[]  @relation("AlvoSalaAvaliacao")
  plantoes         Plantao[]
  criadoEm         DateTime     @default(now())
  atualizadoEm     DateTime     @updatedAt

  @@index([clinicaId])
  @@index([tipo])
  @@index([ativo])
}

model ReservaSala {
  id             String        @id @default(cuid())
  salaId         String
  sala           Sala          @relation(fields: [salaId], references: [id])
  profissionalId String
  profissional   Profissional  @relation(fields: [profissionalId], references: [id])
  data           DateTime
  dataFim        DateTime?
  horaInicio     String
  duracaoHoras   Int
  valorTotal     Int
  valorTotalCentavos BigInt?
  comissaoAoa    Int?
  valorClinicaAoa Int?
  estado         EstadoReserva @default(CONFIRMADA)
  codigoQr       String        @default(cuid())
  pagoEm         DateTime?
  canceladoEm    DateTime?
  motivoCancelamento String?
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt
  pagamentos    Pagamento[]

  @@index([salaId])
  @@index([profissionalId])
  @@index([estado])
}

model Avaliacao {
  id            String        @id @default(cuid())
  tipo          AvaliacaoTipo?
  autorId       String?
  autor         Profissional? @relation("AutorAvaliacao", fields: [autorId], references: [id])
  alvoMedicoId  String?
  alvoMedico    Profissional? @relation("AlvoMedicoAvaliacao", fields: [alvoMedicoId], references: [id])
  alvoClinicaId String?
  alvoClinica   Clinica?      @relation("AlvoClinicaAvaliacao", fields: [alvoClinicaId], references: [id])
  salaId        String?
  sala          Sala?         @relation("AlvoSalaAvaliacao", fields: [salaId], references: [id])
  plantaoId     String?
  plantao       Plantao?      @relation(fields: [plantaoId], references: [id])
  avaliadorUserId String?
  avaliadoUserId String?
  avaliadoRole  String?
  estrelas      Int
  comentario    String?
  criadoEm     DateTime      @default(now())

  @@index([autorId])
  @@index([alvoClinicaId])
  @@index([alvoMedicoId])
  @@index([plantaoId])
}

model Credencial {
  id               String           @id @default(cuid())
  profissionalId   String
  profissional     Profissional     @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  tipo             CredencialTipo
  ficheiroUrl      String?
  ficheiroNome     String?
  ficheiroTamanho  Int?
  estado           CredencialEstado @default(PENDENTE)
  express          Boolean          @default(false)
  comentario       String?
  verificadoPorId  String?
  verificadoPor    User?            @relation("CredencialVerificadaPor", fields: [verificadoPorId], references: [id])
  verificadoEm     DateTime?
  criadoEm         DateTime         @default(now())
  atualizadoEm     DateTime         @updatedAt

  @@index([profissionalId])
  @@index([estado])
}

model DisponibilidadeSala {
  id          String   @id @default(cuid())
  salaId      String
  sala        Sala     @relation(fields: [salaId], references: [id], onDelete: Cascade)
  diaSemana   Int
  horaInicio  String
  horaFim     String
  disponivel  Boolean  @default(true)
  criadoEm    DateTime @default(now())

  @@index([salaId, diaSemana])
}

model Pagamento {
  id                String          @id @default(cuid())
  tipo              PagamentoTipo
  plantaoId         String?
  plantao           Plantao?        @relation(fields: [plantaoId], references: [id])
  candidaturaId     String?
  candidatura       Candidatura?    @relation(fields: [candidaturaId], references: [id])
  reservaSalaId     String?
  reservaSala       ReservaSala?    @relation(fields: [reservaSalaId], references: [id])
  valorBrutoAoa     Int
  comissaoAoa       Int
  valorLiquidoAoa   Int
  metodo            PagamentoMetodo
  estado            PagamentoEstado @default(PENDENTE)
  referenciaExt     String?
  webhookPayload    Json?
  pagoEm            DateTime?
  liberadoEm        DateTime?
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt

  @@index([candidaturaId])
  @@index([reservaSalaId])
  @@index([estado])
  @@index([referenciaExt])
}

model Documento {
  id             String          @id @default(cuid())
  profissionalId String
  profissional   Profissional    @relation(fields: [profissionalId], references: [id])
  tipo           String
  ficheiro       String?
  estado         EstadoDocumento @default(NAO_ENVIADO)
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt
}

model TransacaoCarteira {
  id             String          @id @default(cuid())
  profissionalId String
  profissional   Profissional    @relation(fields: [profissionalId], references: [id])
  tipo           TipoTransacao
  valorCentavos  BigInt
  descricao      String
  referencia     String?
  estado         EstadoTransacao @default(PROCESSADO)
  criadoEm      DateTime        @default(now())

  @@index([profissionalId])
  @@index([tipo])
  @@index([criadoEm])
}

model Notificacao {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  tipo     String
  titulo   String
  corpo    String
  href     String?
  lida     Boolean  @default(false)
  criadoEm DateTime @default(now())

  @@index([userId])
  @@index([lida])
}

